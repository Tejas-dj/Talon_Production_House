# Cloudinary — image delivery (see src/lib/cloudinary-loader.ts, src/lib/media/presets.ts)
# Cloud name only; no API key needed for unsigned delivery URLs.
# Dashboard: https://console.cloudinary.com/ -> top of the page, next to your account name.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Bunny Stream — video delivery on the Volume network (see src/components/media/BunnyPlayer.tsx)
# The PULL ZONE hostname for your Stream library (not the numeric library id):
# Bunny dashboard -> Stream -> your library -> API -> "Pull Zone" / "CDN Hostname",
# looks like "vz-xxxxxxxx-yyy" (used as https://<value>.b-cdn.net/<videoId>/playlist.m3u8).
NEXT_PUBLIC_BUNNY_PULL_ZONE=

# Site URL — used to build absolute URLs in sitemap.ts / robots.ts.
# Leave unset for local dev (falls back to http://localhost:3000).
NEXT_PUBLIC_SITE_URL=
